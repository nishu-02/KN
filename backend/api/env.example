# Django Configuration
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.0.104

# Appwrite Configuration
# Note: For secure authentication, both client-side and server-side keys are needed
APPWRITE_ENDPOINT=https://your-appwrite-endpoint.com
APPWRITE_PROJECT_ID=your-project-id
APPWRITE_API_KEY=your-server-side-api-key  # Required for server-side user verification
APPWRITE_DATABASE_ID=your-database-id
APPWRITE_REPORT_COLLECTION_ID=your-collection-id
APPWRITE_BUCKET_ID=your-bucket-id

# Authentication Settings
# Set to False in production to enforce strict JWT verification
ALLOW_MANUAL_JWT_DECODE=True

# Database Configuration (if using external database)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Email Configuration (if needed)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# Redis Configuration (if using Redis for caching/queues)
# REDIS_URL=redis://localhost:6379/0

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE_LEVEL=INFO 